# ===== GroMo AI Trainer Configuration =====

# Database (PostgreSQL for production, SQLite fallback for local dev)
DATABASE_URL=postgresql://gromo:gromo@db:5432/gromo_ai_trainer

# Redis (required for Celery video generation queue)
REDIS_URL=redis://redis:6379/0

# GroMo API (for product sync)
GROMO_API_BASE_URL=https://api.gromo.in
GROMO_API_KEY=your_api_key_here

# Excluded Categories (comma-separated, insurance is permanently closed)
EXCLUDED_CATEGORIES=insurance,bima

# ===== AI Provider Configuration =====

# LLM Provider: "ollama" | "openai" | "demo"
# "demo" mode generates template-based scripts without any external API
LLM_PROVIDER=demo
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3
OPENAI_API_KEY=

# TTS Provider: "edge_tts" | "coqui" | "demo"
# "edge_tts" uses free Microsoft Edge neural voices (recommended)
# "demo" creates silent audio files for testing
TTS_PROVIDER=edge_tts
ELEVENLABS_API_KEY=

# Avatar Provider: "sadtalker" | "d_id" | "demo"
# All providers fall back to "demo" which creates blue placeholder videos
AVATAR_PROVIDER=demo
HEYGEN_API_KEY=

# ===== Default Settings =====

DEFAULT_LANGUAGE=hinglish
DEFAULT_RESOLUTION=1080p
DEFAULT_VIDEO_SPEED=1.0

# ===== Storage =====

STORAGE_BACKEND=local
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
