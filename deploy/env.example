# ============================================================
# GroMo AI Trainer — Environment Variables
# Copy this to: /home/ubuntu/gromo-ai-trainer/backend/.env
# Fill in your actual API keys
# ============================================================

# Database (SQLite — no setup needed)
DATABASE_URL=sqlite:///storage/gromo_dev.db

# Redis (not needed for basic setup)
REDIS_URL=redis://localhost:6379/0

# GroMo API
GROMO_API_BASE_URL=https://api.gromo.in
GROMO_API_CLIENT_ID=your_client_id_here
GROMO_API_SECRET_KEY=your_secret_key_here
GROMO_API_GPUID=ULTI9999

# Excluded Categories
EXCLUDED_CATEGORIES=insurance,bima

# AI Models
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key-here

# TTS
TTS_PROVIDER=sarvam
SARVAM_API_KEY=your-sarvam-key-here

# Gamma AI
GAMMA_API_KEY=your-gamma-key-here

# Auth
JWT_SECRET=generate-a-random-64-char-string-here
ADMIN_EMAIL=deepak.mishra@gromo.in
ADMIN_PASSWORD=your-admin-password-here
GOOGLE_CLIENT_ID=your-google-client-id-here

# Defaults
DEFAULT_LANGUAGE=hinglish
DEFAULT_RESOLUTION=1080p
DEFAULT_VIDEO_SPEED=1.0

# Storage
STORAGE_BACKEND=local
